#!/usr/bin/env bash

if [ ! -f "assets/webserver/apache2.conf" ]; then
    echo "
invalid current directory, commands can be executed only from the demo directory
"
    exit 1
fi

if [ ! -d "site/moodle" ]; then
    git clone --depth 1 -b MOODLE_501_STABLE https://github.com/moodle/moodle.git site/moodle
fi

exec bin/init "Moodle Demo" "Moodle" "Moodle Demo Site"