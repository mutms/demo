#!/usr/bin/env bash

if [ ! -f "assets/webserver/apache2.conf" ]; then
    echo "
invalid current directory, commands can be executed only from the demo directory
"
    exit 1
fi

if [ ! -d "site" ]; then
    mkdir site
fi

if [ ! -d "site/moodle" ]; then
    git clone -b MOODLE_501_STABLE https://github.com/moodle/moodle.git site/moodle
fi

if [ ! -f "site/moodle/config.php" ]; then
    cp assets/config.php site/moodle/config.php
fi

if [ ! -d "dataroot" ]; then
    mkdir dataroot
fi

if [ ! -d "database" ]; then
    mkdir database
fi

docker-compose up -d
if ! docker-compose exec webserver test -d /var/www/site; then
    docker-compose restart
fi

docker-compose exec webserver bash --login /mdc/composer_install.sh

docker-compose exec webserver php composer.phar install --no-dev --classmap-authoritative

docker-compose exec webserver php admin/cli/install_database.php --fullname="MDL Demo" --shortname="MDL" --summary="Moodle Demo Site" --adminemail="admin@example.com" --adminpass="admin" --agree-license"$@"

echo "
Your Moodle demo site is now available at http://127.0.0.1:9501/
  username is 'admin'
  password is 'admin'
"
