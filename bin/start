#!/usr/bin/env bash

if [ -f "destroy" ]; then
    cd ..
fi

if [ ! -f "assets/webserver/apache2.conf" ]; then
    echo "
invalid current directory, commands can be executed only from the demo directory
"
    exit 1
fi

if [ ! -f "database/postgresql.conf" ]; then
    echo "
DEMO site was not initialised yet, use bin/init
"
    exit 1
fi

docker-compose up -d

docker-compose exec db bash /mdc/mdc-wait.sh

echo "
Your $FULLNAME site is now available at http://127.0.0.1:9501/
"
