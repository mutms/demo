#!/usr/bin/env bash

# First find out if this was called from symlink,
# then find the real path of parent directory.
# This is needed because macOS does not have GNU realpath.
thisfile=$( readlink "${BASH_SOURCE[0]}" ) || thisfile="${BASH_SOURCE[0]}"
cd "$( cd "$( dirname "$thisfile" )/../" && pwd -P )"

if [ ! -f "database/postgresql.conf" ]; then
    echo "
DEMO site was not initialised yet, use bin/init
"
    exit 1
fi

if [ -f ".env" ]; then
    source .env
fi

DEMO_PORT="${DEMO_PORT:-9501}"
DEMO_SHORTNAME="${DEMO_SHORTNAME:-MuTMS}"
DEMO_FULLNAME="${DEMO_FULLNAME:-$DEMO_SHORTNAME}"

docker compose up -d

docker compose exec db bash /mdc/mdc-wait.sh

echo "
Your '${DEMO_FULLNAME}' site is now available at http://127.0.0.1:${DEMO_PORT}/
"
