#!/usr/bin/env bash

# First find out if this was called from symlink,
# then find the real path of parent directory.
# This is needed because macOS does not have GNU realpath.
thisfile=$( readlink "${BASH_SOURCE[0]}" ) || thisfile="${BASH_SOURCE[0]}"
cd "$( cd "$( dirname "$thisfile" )/../" && pwd -P )"

if [ -f ".env" ]; then
    source .env
fi

DEMO_PORT="${1:-${DEMO_PORT:-9501}}"
DEMO_SHORTNAME="${2:-${DEMO_SHORTNAME:-MuTMS}}"
DEMO_FULLNAME="${3:-${DEMO_FULLNAME:-$DEMO_SHORTNAME}}"

if [ ! -d "site" ]; then
    mkdir site
fi

if [ ! -d "site/moodle" ]; then
    git clone --depth 1 -b MuTMS_51 https://github.com/mutms/mutms.git site/moodle
fi

if [ ! -f "site/moodle/config.php" ]; then
    cp assets/config.php site/moodle/config.php
fi

mkdir -p site dataroot database backups

chmod -R 02777 dataroot
chmod -R 02777 database

cat > .env <<EOF
DEMO_PORT=$DEMO_PORT
DEMO_SHORTNAME=$DEMO_SHORTNAME
DEMO_FULLNAME=$DEMO_FULLNAME
EOF

docker compose down
docker compose up -d
if ! docker compose exec -T webserver ls /var/www/site/moodle/ > /dev/null 2>&1; then
    docker compose restart db
    docker compose restart webserver
    sleep 3
fi

docker compose exec webserver bash --login /mdc/composer_install.sh

docker compose exec webserver php composer.phar install --no-dev --classmap-authoritative

docker compose exec webserver php admin/cli/install_database.php \
    --fullname="$DEMO_FULLNAME" \
    --shortname="$DEMO_SHORTNAME" \
    --summary="$DEMO_FULLNAME" \
    --adminemail="admin@example.com" \
    --adminpass="admin" \
    --agree-license

echo "
Your Demo site '${DEMO_FULLNAME}' is now available at http://127.0.0.1:${DEMO_PORT}/
  username is 'admin'
  password is 'admin'
"
