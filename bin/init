#!/usr/bin/env bash

if [ ! -d "site" ]; then
    mkdir site
fi

if [ ! -d "dataroot" ]; then
    mkdir dataroot
fi

if [ ! -d "database" ]; then
    mkdir database
fi


if [ ! -d "site/moodle" ]; then
    git clone -b MuTMS_51 https://github.com/mutms/mutms.git site/moodle
fi

if [ ! -f "site/moodle/config.php" ]; then
    cp assets/config.php site/moodle/config.php
fi

docker-compose up -d

docker-compose exec webserver bash --login /mdc/composer_install.sh

docker-compose exec webserver php composer.phar install --no-dev --classmap-authoritative

docker-compose exec webserver php admin/cli/install_database.php --fullname="MuTMS Demo" --shortname="MuTMS" --summary="MuTMS Demo Site" --adminemail="admin@example.com" --adminpass="admin" --agree-license"$@"

echo "
Your MuTMS demo site is now available at http://127.0.0.1:9501/
  username is 'admin'
  password is 'admin'
"
