#!/usr/bin/env bash

# First find out if this was called from symlink,
# then find the real path of parent directory.
# This is needed because macOS does not have GNU realpath.
thisfile=$( readlink "${BASH_SOURCE[0]}" ) || thisfile="${BASH_SOURCE[0]}"
cd "$( cd "$( dirname "$thisfile" )/../" && pwd -P )"

# --- OrbStack detection -------------------------------------------------------

is_orbstack() {
    # Host-side detection: OrbStack app exists
    if [ -x /Applications/OrbStack.app/Contents/MacOS/orbstack ]; then
        return 0
    fi

    # Docker engine reports OrbStack
    if docker info 2>/dev/null | grep -q "Orbstack"; then
        return 0
    fi

    return 1
}

# --- Enforce sudo unless OrbStack is detected --------------------------------

if ! is_orbstack && [ -z "$SUDO_USER" ]; then
    echo "
ERROR: Backup must be run with sudo unless you are using OrbStack.

Examples:
  sudo bin/backup mybackup
  bin/backup mybackup     # only works on OrbStack

"
    exit 1
fi

# --- Validate environment -----------------------------------------------------

if [ ! -f "dataroot/muc/config.php" ]; then
    echo "
DEMO site was not initialised yet
"
    exit 1
fi

if [ -z "$1" ]; then
    echo "
Backup name is required
"
    exit 1
fi

# Determine the real user even if script is run with sudo
if [ -n "$SUDO_USER" ]; then
    REALUSER="$SUDO_USER"
else
    REALUSER="$USER"
fi
REALGROUP=$(id -gn "$REALUSER")

if [ ! -d "backups" ]; then
    mkdir backups
    chown "$REALUSER":"$REALGROUP" backups
fi

if [ -f "backups/$1.tgz" ]; then
    echo "
Backup already exists, use a different name
"
    exit 1
fi

RUNNING=$(docker compose ps --status running --quiet 2>/dev/null)

if [ -n "$RUNNING" ]; then
    echo "Stopping Docker services ..."
    docker compose stop
fi

echo "Fixing permissions before backup ..."
chmod -R u+rwX database dataroot site

echo "Backing up Demo site into backups/$1.tgz ..."

tar -zcpf backups/$1.tgz database dataroot site demo.env

# Fix ownership so user can delete/overwrite backups without sudo
chown "$REALUSER":"$REALGROUP" "backups/$1.tgz"

echo ""
ls -la backups/$1.tgz
echo ""

# --- Drop sudo privileges before restarting ----------------------------------

echo ""
echo "Restarting Demo site ..."

if [ -n "$SUDO_USER" ]; then
    # Drop SUDO_USER so bin/init does not complain
    exec sudo -u "$REALUSER" env -u SUDO_USER bin/start
else
    exec bin/start
fi
