#!/usr/bin/env bash

if [ -f "destroy" ]; then
    cd ..
fi

if [ ! -f "assets/webserver/apache2.conf" ]; then
    echo "
invalid current directory, commands can be executed only from the demo directory
"
    exit 1
fi

if [ ! -d "site/moodle" ]; then
    echo "
DEMO site was not initialised yet, use bin/init
"
    exit 1
fi

cd site/moodle
git pull

docker compose exec webserver php admin/cli/upgrade.php
