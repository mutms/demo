#!/usr/bin/env bash

if [ -n "$SUDO_USER" ]; then
    echo "
Do not use sudo with bin/update
"
    exit 1
fi

# First find out if this was called from symlink,
# then find the real path of parent directory.
# This is needed because macOS does not have GNU realpath.
thisfile=$( readlink "${BASH_SOURCE[0]}" ) || thisfile="${BASH_SOURCE[0]}"
cd "$( cd "$( dirname "$thisfile" )/../" && pwd -P )"

if [ ! -d "site/moodle" ]; then
    echo "
DEMO site was not initialised yet, use bin/init
"
    exit 1
fi

cd site/moodle
git pull

docker compose exec webserver php admin/cli/upgrade.php
